# 复制本文件为同目录下的 coordinator.env 并填写（coordinator.env 已加入 .gitignore，不会提交）
#
# 协调器在本机执行 coordinator_round.sh 时会自动 source 该文件。

# 主仓库根（含 .trellis/）；默认可由脚本推断，一般可省略
# TRELLIS_REPO_ROOT=/path/to/lpg_gas_project

# 三个 worktree 的绝对路径（与 setup_parallel_worktrees.example.sh 里一致）
TRELLIS_WT_DEV_A=/path/to/worktrees/lpg_gas_project/wt-04
TRELLIS_WT_DEV_B=/path/to/worktrees/lpg_gas_project/wt-17
TRELLIS_WT_INTEGRATE=/path/to/worktrees/lpg_gas_project/wt-integrate

# 本轮任务目录（相对仓库根），与 coordinator_broadcast 一致
COORDINATOR_DEV_A_TASK=.trellis/tasks/05-inventory-lock-revert
COORDINATOR_DEV_B_TASK=.trellis/tasks/06-customer-account-linkage
COORDINATOR_INTEGRATE_TASK=.trellis/tasks/05-inventory-lock-revert

# 写指针后发 macOS 通知：1=开启（默认），0=关闭
COORDINATOR_NOTIFY=1

# 可选：同时写「主仓库」根目录下的 .trellis/.current-task（你在主仓库开协调器会话时用到）
# COORDINATOR_MAIN_REPO_TASK=.trellis/tasks/05-inventory-lock-revert
